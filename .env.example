DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashidb"
PORT=3000

# Auth — REQUERIDO
# En producción generar con: openssl rand -base64 32
JWT_SECRET="dev-secret-change-me-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"

# Cloudflare R2 — OPCIONAL (si todas están definidas, uploads van a R2; si falta cualquiera, van a uploads/ local)
