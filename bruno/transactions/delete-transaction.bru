meta {
  name: Delete Transaction
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/transactions/{{transactionId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  Elimina una transacción por su ID.

  ## Respuesta
  Devuelve 200 con mensaje de confirmación.
  Devuelve 404 si la transacción no existe.
}
