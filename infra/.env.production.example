# Producción — copiar a infra/.env.production en el VPS y completar valores reales.
# NO commitear el archivo con valores reales.

# Conexión a core_postgres (mismo Docker network red_antakarana).
# Usar el usuario y BD que se crean en la Fase 3 (cashi_api / cashidb).
DATABASE_URL=postgresql://cashi_api:CHANGE_ME_password@core_postgres:5432/cashidb

PORT=3000
NODE_ENV=production

# JWT — generar con: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=7d

# Cloudflare R2 — no se usa en este deploy (uploads van al volumen Docker cashi_uploads).
# Dejar comentado para que la estrategia local de src/lib/upload.ts se active.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
