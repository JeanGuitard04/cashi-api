generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

// Un usuario tiene email único y contraseña hasheada con bcrypt.
model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

// Una categoría puede tener muchas transacciones (one-to-many). Globales — no por usuario.
model Category {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  transactions Transaction[]
}

// Una transacción pertenece a un usuario y a una categoría.
model Transaction {
  id          Int             @id @default(autoincrement())
  amount      Int
  type        TransactionType
  description String?
  date        DateTime
  receiptUrl  String?
  latitude    Float?
  longitude   Float?
  category    Category        @relation(fields: [categoryId], references: [id])
  categoryId  Int
  user        User            @relation(fields: [userId], references: [id])
  userId      Int
}
